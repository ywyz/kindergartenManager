# 环境变量配置文件
# 复制此文件为 .env 并填入真实值

# MySQL 数据库配置
DB_HOST=sql.example.com
DB_PORT=3306
DB_USER=username
DB_PASSWORD=your_mysql_password_here
DB_NAME=kindergarten

# 默认 AI API 配置（用户可在设置页面覆盖）
DEFAULT_AI_URL=https://api.openai.com/v1
DEFAULT_AI_KEY=your_openai_api_key_here
DEFAULT_AI_MODEL=gpt-4o

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET_KEY=change_this_to_a_random_secret_key
