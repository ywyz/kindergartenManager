# 数据库连接（可选）
# 留空或删除此行：自动使用内嵌 SQLite（仅适合单机单用户）
# 填写 MySQL 地址：适合多人共用或生产环境
# DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/kindergarten_db
DATABASE_URL=mysql+aiomysql://user:password@localhost:3306/kindergarten_db
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!
JWT_SECRET=your-random-jwt-secret-here
JWT_EXPIRE_MINUTES=60
HOLIDAY_API_URL=https://timor.tech/api/holiday/info/
LOG_LEVEL=INFO

# 对外只读 REST API（二期）。留空 API_KEYS 则对外接口关闭。
# 格式："apikey:tenant_id" 逗号分隔，每个 Key 绑定唯一租户。
API_KEYS=
# HMAC 签名共享密钥；非空时强制校验请求签名。
API_SIGNING_SECRET=
# 签名时间戳允许的最大偏移秒数（防重放）。
API_SIGNATURE_MAX_SKEW=300

# 系统管理员初始化脚本（二阶段）
BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_TENANT_ID=1
BOOTSTRAP_ADMIN_USERNAME=sysadmin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_ALLOW_REMOTE=false
