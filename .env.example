# 幼儿园教学管理系统 — 环境变量配置模板
# 将本文件复制为 .env 并填写必要字段后运行应用。
#
# 零配置快速启动（内嵌 SQLite，适合桌面/演示）：
#   仅填写 ENCRYPTION_KEY 和 JWT_SECRET，其余保留默认即可。
#   ENCRYPTION_KEY / JWT_SECRET 留空时程序自动生成并持久化到 .kindergarten_secrets。

# ── 数据库 ───────────────────────────────────────────────────────────────────
# 留空 → 内嵌 SQLite（数据存于程序同目录 kindergarten.db）
# MySQL 示例：mysql+aiomysql://user:password@localhost:3306/kindergarten_db
DATABASE_URL=

# ── 密钥（生产/服务器环境强烈建议显式配置） ──────────────────────────────────
# 留空时程序自动生成并保存到 .kindergarten_secrets
# 生产环境请固化此值，否则重装/重启后已加密数据将无法解密
ENCRYPTION_KEY=
JWT_SECRET=
JWT_EXPIRE_MINUTES=60

# ── 节假日 API ────────────────────────────────────────────────────────────────
HOLIDAY_API_URL=https://timor.tech/api/holiday/info/
LOG_LEVEL=INFO

# ── 管理员初始化引导（可选，脚本方式初始化时使用） ───────────────────────────
# BOOTSTRAP_ADMIN_ENABLED=false
# BOOTSTRAP_ADMIN_TENANT_ID=1
# BOOTSTRAP_ADMIN_USERNAME=sysadmin
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_ALLOW_REMOTE=false

# ── 对外只读 REST API（二期，默认关闭） ─────────────────────────────────────
# 格式："apikey:tenant_id" 逗号分隔，例如 "svc-abc:1,svc-xyz:2"；留空则接口关闭
API_KEYS=
# HMAC-SHA256 签名共享密钥；非空时强制校验请求签名
API_SIGNING_SECRET=
API_SIGNATURE_MAX_SKEW=300
