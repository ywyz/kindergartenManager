# 环境与密钥
.env
.env.prod
.env.local
.kindergarten_secrets

# 虚拟环境
.venv/
.venv.bak*/
venv/
env/

# Python 缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# NiceGUI 运行时存储（session 状态，不入仓）
