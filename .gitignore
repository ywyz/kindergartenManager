# IDE
.idea/
.vscode/settings.json
.vscode/*.code-snippets
*.swp
*.swo

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/

# 构建产物
dist/
build/
*.egg-info/

# 日志
*.log
